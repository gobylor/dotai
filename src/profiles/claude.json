  "name": "claude",
  "description": "Claude Code by Anthropic",
  "configDir": "~/.claude",
  "portable": ["settings.json", "commands/", "skills/", "plugins/config.json", "plugins/installed_plugins.json", "plugins/known_marketplaces.json", "plugins/blocklist.json", "statusline-command.sh", "hooks/", "agents/", "rules/", "CLAUDE.md", "keybindings.json"],
  "ephemeral": ["sessions/", "session-env/", "cache/", "shell-snapshots/", "debug/", "paste-cache/", "file-history/", "plans/", "ide/", "backups/", "history.jsonl", ".session-stats.json", "policy-limits.json", "mcp-needs-auth-cache.json", "statsig/", "stats-cache.json", "plugins/cache/", "plugins/data/", "plugins/marketplaces/", "plugins/repos/", "plugins/install-counts-cache.json"],
  "credentials": ["auth.json"],
  "postImport": {
    "type": "claude-plugins",
